#First pass
primaryRef <- readRDS("/x") #(Polioudakis et al., 2019)
gc()
celltypeMapping <- "Cluster"

#PCA, harmony & UMAP of primary reference
primaryRef <- RunPCA(primaryRef, features = VariableFeatures(object = primaryRef))

set.seed(123)
primaryRef <- primaryRef %>%
  RunHarmony(c("Library"), plot_convergence = TRUE)
harmony_embeddings <- Embeddings(primaryRef, 'harmony')

primaryRef <- primaryRef %>%
  FindNeighbors(reduction = "pca", dims = 1:15) %>%
  FindClusters(resolution = 0.8) %>%
  identity()
secondaryRef <- RunUMAP(secondaryRef, dims = 1:15, reduction = "pca", n.neighbors = 10, reduction.name = "umap", reduction.key = "UMAP_", return.model = T)

#Harmony Ref
primaryRef[['harmony2']] <- CreateDimReducObject(embeddings = primaryRef[['harmony']]@cell.embeddings,
                                                 key = "harmony2_",
                                                 loadings = primaryRef[['pca']]@feature.loadings,
                                                 assay = "RNA")

#Query Ref
query[['pca']] <- CreateDimReducObject(embeddings = query[['pca']]@cell.embeddings,
                                                 key = "PC_",
                                                 loadings = query[['pca']]@feature.loadings,
                                                 assay = "RNA")

#Map-reference
anchor  <- FindTransferAnchors(reference = primaryRef,
                                                 reference.reduction = "pca",
                                                 query = query ,
                                                 dims = 1:30)
                                  
query <- MapQuery(anchorset = anchor,
                        query = query,
                        reference = primaryRef,
                        refdata = list(celltype = celltypeMapping),
                        #reduction.model = "umap.harmony",
                        reduction.model = "pca",
                        store.weights = TRUE)

#Give a robustID name and save mapping results

dfResults <- data.frame(robustId=rownames(query@meta.data),
                        predicted.celltype=query$predicted.celltype,
                        predicted.celltype.score=query$predicted.celltype.score,
                        mapRef="primaryMapRef_Polioudakis")

print("Percentage of cells with predicted.cell.type.score > 0.5")
print(round(table(dfResults$predicted.celltype.score>0.5)["TRUE"]*100/sum(table(dfResults$predicted.celltype.score>0.5)),2))

saveRDS(dfResults, paste0(resultsDir,"x"))

meta_df <- t(query@assays$prediction.score.celltype["data"])

saveRDS(meta_df, file=paste0(resultsDir,"x.RDS"))

query$mid_unmapped_bucket <- ifelse(query$predicted.celltype.score > 0.5, query$predicted.celltype, "Unmapped")

plotToPdf <- DimPlot(query, reduction = "umap.pca", label = FALSE, pt.size = .1, group.by="mid_unmapped_bucket")+theme_gray()+
  theme(plot.title=element_text(hjust=0.5, size=13, face="bold"))+
  ggtitle("FirstPass Annots")+theme_bw()+facet_wrap(~mid_unmapped_bucket)+gghighlight()
  pdf(file=paste0(resultsDir,"UMAP_firstPassAnnots.pdf"))
  plot(plotToPdf)
  dev.off()

saveRDS(query, paste0(resultsDir,"x.RDS"))

rm(anchor, primaryRef)

#Second pass

secondaryRef <- readRDS("/x.RDS") #(Bhaduri et al., 2020)
celltypeMapping <- "typeSubType"

#PCA, harmony & UMAP of secondary reference
secondaryRef <- RunPCA(secondaryRef, features = VariableFeatures(object = secondaryRef))

secondaryRef <- secondaryRef %>%
  FindNeighbors(reduction = "pca", dims = 1:15) %>%
  FindClusters(resolution = 0.8) %>%
  identity()
secondaryRef <- RunUMAP(secondaryRef, dims = 1:15, reduction = "pca", n.neighbors = 10, reduction.name = "umap", reduction.key = "UMAP_", return.model = T)


#Map-reference
anchor  <- FindTransferAnchors(reference = secondaryRef,
                               reference.reduction = "pca",
                               query = query ,
                               dims = 1:30)

query <- MapQuery(anchorset = anchor,
                              query = query,
                              reference = secondaryRef,
                              refdata = list(celltype = celltypeMapping),
                              reduction.model = "umap",
                              store.weights = TRUE)


#Give a robustID name and save mapping results
dfResults <- data.frame(robustId=rownames(query@meta.data),
                        predicted.celltype=query$predicted.celltype,
                        predicted.celltype.score=query$predicted.celltype.score,
                        mapRef="secondaryMapRef_BhaduriOrganoids")

print("Percentage of cells with predicted.cell.type.score > 0.5")
print(round(table(dfResults$predicted.celltype.score>0.5)["TRUE"]*100/sum(table(dfResults$predicted.celltype.score>0.5)),2))

saveRDS(dfResults, file=paste0(resultsDir,"resultsDF_MapRef_BhaduriOrganoids.RDS"))

meta_df <- t(query@assays$prediction.score.celltype["data"])

saveRDS(meta_df, file=paste0(resultsDir,"metadata_MapRef_BhaduriOrganoids.RDS"))

query$org_unmapped_bucket <- ifelse(query$predicted.celltype.score > 0.5, paste0(query$predicted.celltype,"-O"), "Unmapped")

plotToPdf <- DimPlot(query, reduction = "umap.pca", label = FALSE, pt.size = .1, group.by="org_unmapped_bucket")+theme_gray()+
  theme(plot.title=element_text(hjust=0.5, size=13, face="bold"))+
  ggtitle("SecondPassAnnots")+theme_bw() +facet_wrap(~org_unmapped_bucket)+gghighlight()
  pdf(file=paste0(resultsDir,"UMAP_secondPassAnnots.pdf"))
  plot(plotToPdf)
  dev.off()

query$final <- query$mid_unmapped_bucket
query$final[which(query$final=='Unmapped')] <- query$org_unmapped_bucket[which(query$final=='Unmapped')]
tt <- table(query$final)
tt <- (tt/sum(tt))*100
tt

plotToPdf <- DimPlot(query, reduction = "umap.pca", label = FALSE, pt.size = .1, group.by="final")+theme_gray()+
  theme(plot.title=element_text(hjust=0.5, size=13, face="bold"))+
  ggtitle("TwoPass Annots")+theme_bw() +gghighlight() +facet_wrap(~final)
  pdf(file=paste0(resultsDir,"UMAP_twoPassAnnots.pdf"))
  plot(plotToPdf)
  dev.off()

saveRDS(query, paste0(resultsDir,"x.RDS"))

rm(anchor, secondaryRef)

query <- readRDS("/x.RDS")

#Combine confident predictions with any unmapped cells
query$final <- query$mid_unmapped_bucket
query$final[query$final == "Unmapped"] <- query$org_unmapped_bucket[query$final == "Unmapped"]


  ct_counts    <- filter(cell_counts, final == ct)
  valid_donors <- ct_counts %>% filter(n_cells >= 50) %>% pull(donor)
  excluded     <- ct_counts %>% filter(n_cells < 50)
  
  if (nrow(excluded) > 0) {
    cat("  Excluding donors with < 50 cells:\n")
    print(excluded)
  }
  
  valid_meta <- ct_counts %>% filter(donor %in% valid_donors)
  group_n    <- table(valid_meta$patientDisease)
  
  cat("  Valid donors per group:\n")
  print(group_n)
  
  if (length(group_n) < 2 || any(group_n < 2)) {
    cat("  Skipping — not enough donors per group\n")
    next
  }
  
  #Pseudobulk
  seurat_ct <- subset(seurat_obj,
                      subset = final == ct & donor %in% valid_donors)
  
  pb_ct      <- make_pseudobulk(seurat_ct, group_vars = c("donor", "final", "patientDisease"))
  rm(seurat_ct); gc()
  
  counts_ct              <- pb_ct$counts
  meta_ct                <- pb_ct$meta
  
  # Sanitize factor levels: replace spaces with underscores so DESeq2's
  # model.matrix does not choke on "Intellectual disability"
  meta_ct$patientDisease <- droplevels(
    factor(gsub(" ", "_", meta_ct$patientDisease))
  )
  
  
  dds_pca <- DESeqDataSetFromMatrix(countData = counts_ct,
                                    colData   = meta_ct,
                                    design    = ~ patientDisease)
  dds_pca$patientDisease <- relevel(dds_pca$patientDisease, ref = "Normal")
  dds_pca <- dds_pca[rowSums(counts(dds_pca) >= 5) >= 2, ]
  vst_data <- vst(dds_pca, blind = TRUE)
  
  #DESeq2
  dds <- DESeqDataSetFromMatrix(countData = counts_ct,
                                colData   = meta_ct,
                                design    = ~ patientDisease)
  dds$patientDisease <- relevel(dds$patientDisease, ref = "Normal")
  dds <- dds[rowSums(counts(dds) >= 5) >= 2, ]
  dds <- DESeq(dds)
  
  res <- results(dds,
                 contrast = c("patientDisease", "Intellectual_disability", "Normal"),
                 alpha    = 0.05) %>%
    as.data.frame() %>%
    filter(!is.na(padj)) %>%
    arrange(padj)
  
  n_sig <- sum(res$padj < 0.05 & abs(res$log2FoldChange) > 1)
  cat("  Significant DE genes (padj < 0.05, |LFC| > 1):", n_sig, "\n")
  
  write.csv(res,
            file.path(resultsDir,
                      paste0("DE_", gsub("/", "-", ct), "_Patient_vs_Normal.csv")))
  
  #Volcano plot
  res_plot      <- res
  res_plot$gene <- rownames(res_plot)
  res_plot$sig  <- case_when(
    res_plot$padj < 0.05 & res_plot$log2FoldChange >  1 ~ "Up in Patient",
    res_plot$padj < 0.05 & res_plot$log2FoldChange < -1 ~ "Down in Patient",
    TRUE ~ "NS"
  )
  
  top_genes <- res_plot %>%
    filter(sig != "NS") %>%
    arrange(padj) %>%
    head(15)
  
  p_volc <- ggplot(res_plot, aes(log2FoldChange, -log10(padj), colour = sig)) +
    geom_point(alpha = 0.5, size = 1.2) +
    geom_text_repel(data = top_genes, aes(label = gene),
                    size = 2.8, max.overlaps = 20, segment.size = 0.3) +
    scale_colour_manual(values = c("Up in Patient"   = "firebrick",
                                   "Down in Patient" = "steelblue",
                                   "NS"              = "grey70")) +
    geom_vline(xintercept = c(-1, 1), linetype = "dashed",
               colour = "grey40", linewidth = 0.4) +
    geom_hline(yintercept = -log10(0.05), linetype = "dashed",
               colour = "grey40", linewidth = 0.4) +
    labs(title    = paste0(ct, ": Patient vs Normal"),
         subtitle = "Red = up in patient | Blue = down in patient | |LFC| > 1",
         x        = expression(log[2]~"Fold Change (Patient / Normal)"),
         y        = expression(-log[10]~"(adjusted p-value)"),
         colour   = "") +
    theme_classic(base_size = 11) +
    theme(legend.position = "bottom", plot.title = element_text(hjust = 0.5))
  
  ggsave(file.path(resultsDir, paste0("Volcano_", gsub("/", "-", ct), ".pdf")),
         plot = p_volc, width = 7, height = 6)
  cat("  Volcano saved\n")
  
  #Heatmap of top DE genes
  # Log-normalised average expression per donor, Z-scored per gene.
  
  sig_genes <- res %>%
    filter(padj < 0.05, abs(log2FoldChange) > 1) %>%
    arrange(padj) %>%
    head(20) %>%
    rownames()
  
  if (length(sig_genes) >= 2) {
    
    seurat_ct_hm <- subset(seurat_obj,
                           subset = final == ct & donor %in% valid_donors)
    
    avg_expr <- AverageExpression(seurat_ct_hm,
                                  features = sig_genes,
                                  group.by = "donor",
                                  assays   = "RNA",
                                  layer    = "data")$RNA
    rm(seurat_ct_hm); gc()
    
    donor_anno <- data.frame(
      Condition = case_when(
        grepl("312.3", colnames(avg_expr)) ~ "Patient_312.3",
        grepl("315.7", colnames(avg_expr)) ~ "Patient_315.7",
        TRUE                               ~ "Normal"
      ),
      row.names = colnames(avg_expr)
    )
    
    col_order <- c(rownames(donor_anno)[donor_anno$Condition == "Normal"],
                   rownames(donor_anno)[donor_anno$Condition == "Patient_312.3"],
                   rownames(donor_anno)[donor_anno$Condition == "Patient_315.7"])
    col_order  <- col_order[col_order %in% colnames(avg_expr)]
    avg_expr   <- avg_expr[, col_order, drop = FALSE]
    donor_anno <- donor_anno[col_order, , drop = FALSE]
    
    row_sd   <- apply(avg_expr, 1, sd)
    avg_expr <- avg_expr[row_sd > 0, ]
    scaled   <- pmin(pmax(t(scale(t(avg_expr))), -2), 2)
    
    ann_colours <- list(Condition = c(Normal        = "steelblue",
                                      Patient_312.3 = "tomato",
                                      Patient_315.7 = "darkorange"))
    
    outfile <- file.path(resultsDir, paste0("Heatmap_", gsub("/", "-", ct), ".pdf"))
    pdf(outfile,
        width  = max(6, ncol(scaled) * 0.8 + 3),
        height = max(8, nrow(scaled) * 0.20 + 3))
    pheatmap(scaled,
             annotation_col    = donor_anno,
             annotation_colors = ann_colours,
             cluster_cols      = FALSE,
             cluster_rows      = TRUE,
             color             = rev(colorRampPalette(brewer.pal(11, "RdYlBu"))(100)),
             main              = paste0(ct, ": Top DE Genes\nZ-scored log-normalised expression"),
             fontsize_row      = max(12, min(20, 200 / nrow(scaled))),
             fontsize_col      = 10,
             show_rownames     = TRUE,
             show_colnames     = TRUE,
             border_color      = NA)
    dev.off()
    cat("  Heatmap saved:", outfile, "\n")
    
  } else {
    cat("  Not enough significant genes for heatmap\n")
  }
  
  #GO enrichment
  universe_genes <- rownames(res)
  
  genes_up   <- rownames(filter(res, padj < 0.05, log2FoldChange >  1))
  genes_down <- rownames(filter(res, padj < 0.05, log2FoldChange < -1))
  
  cat("  GO — genes up:", length(genes_up),

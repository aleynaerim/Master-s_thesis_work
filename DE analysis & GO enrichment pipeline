  #Helper function definitions
  #Pseudobulk

  make_pseudobulk <- function(seurat_obj, group_vars) {
  
  counts   <- GetAssayData(seurat_obj, layer = "counts")
  meta     <- seurat_obj@meta.data
  
  meta$group_id <- apply(meta[, group_vars, drop = FALSE], 1,
                         paste, collapse = "_")
  groups <- unique(meta$group_id)
  
  pb_matrix <- sapply(groups, function(g) {
    cells <- rownames(meta)[meta$group_id == g]
    rowSums(counts[, cells, drop = FALSE])
  })
  
  pb_meta <- meta[match(groups, meta$group_id), group_vars, drop = FALSE]
  rownames(pb_meta) <- groups
  pb_meta <- pb_meta[colnames(pb_matrix), , drop = FALSE]
  
  list(counts = pb_matrix, meta = pb_meta)
}


#GO enrichment
#Universe = all genes tested by DESeq2

run_GO <- function(genes, universe, label, ct, resultsDir,
                   lfc_direction = "up") {
  
  if (length(genes) < 10) {
    cat("  Skipping GO for", label, "— fewer than 5 genes\n")
    return(NULL)
  }
  
  lfc_label <- if (lfc_direction == "up") "LFC > 1" else "LFC < -1"
  subtitle  <- paste0(ct, " | ", label, " | ", lfc_label)
  
  bp <- enrichGO(gene          = genes,
                 universe      = universe,
                 keyType       = "SYMBOL",
                 OrgDb         = org.Hs.eg.db,
                 ont           = "BP",
                 pAdjustMethod = "BH",
                 qvalueCutoff  = 0.01,
                 readable      = TRUE)
  
  cc <- enrichGO(gene          = genes,
                 universe      = universe,
                 keyType       = "SYMBOL",
                 OrgDb         = org.Hs.eg.db,
                 ont           = "CC",
                 pAdjustMethod = "BH",
                 qvalueCutoff  = 0.01,
                 readable      = TRUE)
  
  mf <- enrichGO(gene          = genes,
                 universe      = universe,
                 keyType       = "SYMBOL",
                 OrgDb         = org.Hs.eg.db,
                 ont           = "MF",
                 pAdjustMethod = "BH",
                 qvalueCutoff  = 0.01,
                 readable      = TRUE)
  
  #Only include ontologies that returned significant terms
  plots <- list()
  if (!is.null(bp) && nrow(bp) > 0)
    plots$bp <- dotplot(bp, showCategory = 15) +
    ggtitle("Biological Process", subtitle = subtitle) +
    scale_y_discrete(labels = function(x) stringr::str_trunc(x, 40)) +
    theme(axis.text.y = element_text(size = 25))
  if (!is.null(cc) && nrow(cc) > 0)
    plots$cc <- dotplot(cc, showCategory = 15) +
    ggtitle("Cellular Component", subtitle = subtitle) +
    scale_y_discrete(labels = function(x) stringr::str_trunc(x, 40))
  if (!is.null(mf) && nrow(mf) > 0)
    plots$mf <- dotplot(mf, showCategory = 15) +
    ggtitle("Molecular Function", subtitle = subtitle) +
    scale_y_discrete(labels = function(x) stringr::str_trunc(x, 40))
  
  if (length(plots) == 0) {
    cat("  No significant GO terms for", label, "\n")
    return(NULL)
  }
  
  # Scale height to number of terms so rows never overlap
  n_terms <- min(15, max(sapply(list(bp, cc, mf), function(x)
    if (!is.null(x) && nrow(x) > 0) nrow(x) else 0)))
  
  pdf(file.path(resultsDir,
                paste0("GO_", gsub("/", "-", ct), "_", label, ".pdf")),
      width  = 12 * length(plots),
      height = max(6, n_terms * 0.6 + 2))
  print(plot_grid(plotlist = plots, ncol = length(plots)))
  dev.off()
  
  cat("  GO saved for", ct, "-", label, "\n")
  return(list(BP = bp, CC = cc, MF = mf))
}

  #Main loop that works on each pseudobulked cell type

  cell_types <- unique(seurat_obj$final)

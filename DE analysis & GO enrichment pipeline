  run_GO(genes_up,   universe_genes, "Upregulated",   ct, resultsDir, lfc_direction = "up")
  run_GO(genes_down, universe_genes, "Downregulated", ct, resultsDir, lfc_direction = "down")

  #Summary table
  
  summary_df <- data.frame(
    cell_type = names(de_results),
    n_tested  = sapply(de_results, function(x) nrow(x$res)),
    n_sig     = sapply(de_results, function(x) sum(x$res$padj < 0.05 & abs(x$res$log2FoldChange) > 1)),
    n_up      = sapply(de_results, function(x) sum(x$res$padj < 0.05 & x$res$log2FoldChange >  1)),
    n_down    = sapply(de_results, function(x) sum(x$res$padj < 0.05 & x$res$log2FoldChange < -1))
  ) %>% arrange(desc(n_sig))
  
  cat("\n=== DE summary across cell types ===\n")
  print(summary_df)
  
  write.csv(summary_df,
            file.path(resultsDir, "DE_summary_all_celltypes.csv"),
            row.names = FALSE)

  #Mirror barplot of DEGs
  #Assign negative values to downregulated so bars mirror around x = 0

bar_df <- summary_df %>%
  # Order factor levels: most total DEGs at top of y-axis
  mutate(cell_type = factor(cell_type,
                            levels = cell_type[order(n_up + n_down)])) %>%
  dplyr::select(cell_type, n_up, n_down) %>%
  pivot_longer(cols      = c(n_up, n_down),
               names_to  = "direction",
               values_to = "count") %>%
  mutate(
    #Downregulated counts become negative → bars go left
    count_signed = ifelse(direction == "n_down", -count, count),
    direction    = recode(direction,
                          n_up   = "Up in patient",
                          n_down = "Down in patient"))

  #Determine x-axis limits (symmetric around 0)
  x_max <- max(abs(bar_df$count_signed), na.rm = TRUE) * 1.15
  
  #Plot
  p_mirror_bar <- ggplot(bar_df,
                         aes(x    = count_signed,
                             y    = cell_type,
                             fill = direction)) +
    
  geom_col(width = 0.65, colour = "white", linewidth = 0.25) +
  
  #Add count labels inside/outside bars
  geom_text(aes(label = abs(count_signed),
                hjust = ifelse(count_signed >= 0, -0.25, 1.25)),
            size = 3, colour = "grey30") +
  
  #Vertical line at x = 0 (the mirror axis)
  geom_vline(xintercept = 0, linewidth = 0.5, colour = "grey40") +
  
  scale_fill_manual(
    values = c("Up in patient"   = "#C0392B",   # red
               "Down in patient" = "#2980B9"),   # blue
